      <h1>Новое обращение</h1>
      <form method="POST" action="/tickets/new">
        <input name="title" placeholder="Тема" required>
        <textarea name="description" placeholder="Опишите проблему"></textarea>
        <button>Отправить</button>
      </form>
      <a href="/dashboard">Назад</a>
    </body></html>
  `);
