      <button>Зарегистрироваться</button>
    </form>
    <a href="/login">Уже есть аккаунт? Войти</a></body></html>
  `);
});

app.post('/register', (req, res) => {
  const { username, email, password } = req.body;
  if (!username || !email || !password) return res.send('Все поля обязательны');
  try {
    const hash = bcrypt.hashSync(password, 10);
    db.prepare('INSERT INTO users (username, email, password) VALUES (?, ?, ?)').run(username, email, hash);
    res.redirect('/login');
  } catch (e) {
    res.send('Ошибка: пользователь или email уже заняты. <a href="/register">Назад</a>');
  }
});

// Вход
app.get('/login', (req, res) => {
  res.send(`
    <!DOCTYPE html><html><head><meta charset="UTF-8"><title>Вход</title>
    <style>body{font-family:sans-serif;max-width:400px;margin:40px auto;}input,button{display:block;width:100%;margin:8px 0;padding:8px;}</style></head>
    <body><h1>Вход</h1>
    <form method="POST" action="/login">
      <input name="email" type="email" placeholder="Email" required>
      <input name="password" type="password" placeholder="Пароль" required>
      <button>Войти</button>
    </form>
    <a href="/register">Создать аккаунт</a></body></html>
  `);
});

app.post('/login', (req, res) => {
  const { email, password } = req.body;
  const user = db.prepare('SELECT * FROM users WHERE email = ?').get(email);
  if (!user || !bcrypt.compareSync(password, user.password)) {
    return res.send('Неверный email или пароль. <a href="/login">Попробовать снова</a>');
  }
  req.session.userId = user.id;
  req.session.username = user.username;
  if (user.role === 'admin') return res.redirect('/admin');
  res.redirect('/dashboard');
});

app.get('/logout', (req, res) => {
  req.session.destroy();
  res.redirect('/login');
});

// Личный кабинет пользователя
app.get('/dashboard', auth, (req, res) => {
  const tickets = db.prepare('SELECT * FROM tickets WHERE user_id = ? ORDER BY created_at DESC').all(req.session.userId);
  let ticketsHtml = tickets.map(t => `
    <li><a href="/tickets/${t.id}">${t.title}</a> [${t.status}] <small>${t.created_at}</small></li>
  `).join('');
  if (!tickets.length) ticketsHtml = '<p>У вас пока нет тикетов.</p>';

  res.send(`
    <!DOCTYPE html><html><head><meta charset="UTF-8"><title>Поддержка</title>
    <style>body{font-family:sans-serif;max-width:600px;margin:40px auto;} a{margin-right:10px;}</style></head>
    <body>
      <h1>Добро пожаловать, ${req.session.username}!</h1>
      <a href="/tickets/new">Создать обращение</a> | <a href="/logout">Выйти</a>
      <h2>Ваши обращения</h2><ul>${ticketsHtml}</ul>
    </body></html>
  `);
});

// Создание тикета
app.get('/tickets/new', auth, (req, res) => {
