app.post('/tickets/new', auth, (req, res) => {
  const { title, description } = req.body;
  if (!title) return res.send('Тема обязательна. <a href="/tickets/new">Назад</a>');
  db.prepare('INSERT INTO tickets (user_id, title, description) VALUES (?, ?, ?)').run(req.session.userId, title, description);
  res.redirect('/dashboard');
});

// Просмотр тикета и переписка
app.get('/tickets/:id', auth, (req, res) => {
  const ticket = db.prepare(`
    SELECT tickets.*, users.username FROM tickets
    JOIN users ON tickets.user_id = users.id
    WHERE tickets.id = ?`).get(req.params.id);
  if (!ticket) return res.status(404).send('Тикет не найден');

  const currentUser = db.prepare('SELECT role FROM users WHERE id = ?').get(req.session.userId);
  if (ticket.user_id !== req.session.userId && currentUser.role !== 'admin') {
    return res.status(403).send('Доступ запрещён');
  }

  const replies = db.prepare(`
    SELECT replies.*, users.username FROM replies
    JOIN users ON replies.user_id = users.id
    WHERE ticket_id = ? ORDER BY created_at ASC`).all(req.params.id);

  let repliesHtml = replies.map(r => `
    <div style="border:1px solid #ccc; padding:8px; margin:6px 0;">
      <strong>${r.username}</strong> <small>${r.created_at}</small>
      <p>${r.message}</p>
    </div>
  `).join('');
  if (!replies.length) repliesHtml = '<p>Ответов пока нет.</p>';

  const isAdmin = currentUser.role === 'admin';
  const backLink = isAdmin ? '/admin' : '/dashboard';

  res.send(`
    <!DOCTYPE html><html><head><meta charset="UTF-8"><title>${ticket.title}</title>
    <style>body{font-family:sans-serif;max-width:600px;margin:40px auto;}textarea{width:100%;}</style></head>
    <body>
      <h1>${ticket.title}</h1>
      <p>${ticket.description || 'Без описания'}</p>
      <p>Статус: <strong>${ticket.status}</strong> | Автор: ${ticket.username}</p>
      <h2>Переписка</h2>${repliesHtml}
      <h3>Добавить ответ</h3>
      <form method="POST" action="/tickets/${ticket.id}/reply">
        <textarea name="message" required placeholder="Ваше сообщение..."></textarea>
        <button>Ответить</button>
      </form>
      <p><a href="${backLink}">Назад</a></p>
    </body></html>
  `);
});

app.post('/tickets/:id/reply', auth, (req, res) => {
  const ticket = db.prepare('SELECT * FROM tickets WHERE id = ?').get(req.params.id);
  const currentUser = db.prepare('SELECT role FROM users WHERE id = ?').get(req.session.userId);
  if (!ticket) return res.status(404).send('Тикет не найден');
  if (ticket.user_id !== req.session.userId && currentUser.role !== 'admin') {
    return res.status(403).send('Доступ запрещён');
  }
  const { message } = req.body;
  if (!message) return res.redirect(`/tickets/${req.params.id}`);
  db.prepare('INSERT INTO replies (ticket_id, user_id, message) VALUES (?, ?, ?)').run(req.params.id, req.session.userId, message);
  res.redirect(`/tickets/${req.params.id}`);
});

// Админ-панель
app.get('/admin', adminOnly, (req, res) => {
  const tickets = db.prepare(`
    SELECT tickets.*, users.username FROM tickets
    JOIN users ON tickets.user_id = users.id
    ORDER BY tickets.created_at DESC`).all();

  let list = tickets.map(t => `
    <li>
      <a href="/tickets/${t.id}">${t.title}</a> от ${t.username} [${t.status}]
      <form method="POST" action="/admin/tickets/${t.id}/toggle" style="display:inline">
        <button>${t.status === 'open' ? 'Закрыть' : 'Открыть'}</button>
      </form>
    </li>
  `).join('');
  if (!list) list = '<p>Обращений нет.</p>';

  res.send(`
    <!DOCTYPE html><html><head><meta charset="UTF-8"><title>Админ-панель</title>
    <style>body{font-family:sans-serif;max-width:700px;margin:40px auto;}</style></head>
    <body>
      <h1>Панель администратора</h1>
      <a href="/logout">Выйти</a>
      <h2>Все обращения</h2><ul>${list}</ul>
    </body></html>
  `);
});

app.post('/admin/tickets/:id/toggle', adminOnly, (req, res) => {
  const ticket = db.prepare('SELECT status FROM tickets WHERE id = ?').get(req.params.id);
  if (!ticket) return res.status(404).send('Тикет не найден');
  const newStatus = ticket.status === 'open' ? 'closed' : 'open';
  db.prepare('UPDATE tickets SET status = ? WHERE id = ?').run(newStatus, req.params.id);
  res.redirect('/admin');
});

// Главная
app.get('/', (req, res) => {
  if (req.session.userId) {
    const user = db.prepare('SELECT role FROM users WHERE id = ?').get(req.session.userId);
    return res.redirect(user.role === 'admin' ? '/admin' : '/dashboard');
  }
  res.redirect('/login');
});

const PORT = process.env.PORT || 3000;
app.listen(PORT, () => {
  console.log(`Сервер запущен: http://localhost:${PORT}`);
});
